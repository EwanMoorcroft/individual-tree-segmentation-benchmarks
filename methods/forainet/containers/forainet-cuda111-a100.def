Bootstrap: docker
From: nvidia/cuda@sha256:83e4b2841034cdf45ea5b9a5b472eb2c07b1b23d4836d32666a881db29a8dceb

%labels
    org.opencontainers.image.title ForAINet qualification runtime
    org.opencontainers.image.source https://github.com/prs-eth/ForAINet
    org.opencontainers.image.revision 5fe600ae8f2fe913ae8740f475f0261a702f2a72
    org.opencontainers.image.licenses BSD-3-Clause
    org.treebench.cuda.arch 8.0
    org.treebench.minkowski.commit 9f81ae66b33b883cd08ee4f64d08cf633608b118
    org.treebench.torchsparse.commit 74099d10a51c71c14318bce63d6421f698b24f24
    org.treebench.hdbscan.commit ec3b205fbd7da9f1e41b9d83cdf3f6236e2ef1c4

%files
    methods/forainet/containers/requirements.lock /opt/forainet/requirements.lock

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONNOUSERSITE=1
    export TORCH_CUDA_ARCH_LIST=8.0

%post
    set -eux
    export DEBIAN_FRONTEND=noninteractive
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PYTHONNOUSERSITE=1
    export TORCH_CUDA_ARCH_LIST=8.0
    export FORCE_CUDA=1

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        language-pack-en-base \
        less \
        libglib2.0-0 \
        libglu1-mesa-dev \
        libopenblas-dev \
        libosmesa6-dev \
        libsm6 \
        libsndfile1 \
        libsparsehash-dev \
        libtbb-dev \
        libusb-1.0-0-dev \
        libxcb-shm0 \
        libxext6 \
        libxrender-dev \
        python3.8 \
        python3.8-dev \
        python3-pip \
        unzip \
        wget

    python3.8 -m pip install --no-cache-dir --upgrade \
        pip==21.2.4 \
        setuptools==58.0.4 \
        wheel==0.37.0 \
        ninja==1.10.2 \
        Cython==0.29.30

    python3.8 -m pip install --no-cache-dir \
        torch==1.9.0+cu111 \
        torchvision==0.10.0+cu111 \
        torchaudio==0.9.0 \
        -f https://download.pytorch.org/whl/torch_stable.html

    python3.8 -m pip install --no-cache-dir \
        torch-scatter==2.0.8 \
        torch-sparse==0.6.12 \
        torch-cluster==1.5.9 \
        torch-spline-conv==1.2.1 \
        torch-geometric==1.7.2 \
        -f https://data.pyg.org/whl/torch-1.9.0+cu111.html

    python3.8 -m pip install --no-cache-dir torch-points-kernels==0.7.0

    python3.8 -m pip install --no-cache-dir \
        --requirement /opt/forainet/requirements.lock

    mkdir -p /opt/forainet/src
    git clone https://github.com/NVIDIA/MinkowskiEngine.git \
        /opt/forainet/src/MinkowskiEngine
    git -C /opt/forainet/src/MinkowskiEngine checkout --detach \
        9f81ae66b33b883cd08ee4f64d08cf633608b118
    test "$(git -C /opt/forainet/src/MinkowskiEngine rev-parse HEAD)" = \
        9f81ae66b33b883cd08ee4f64d08cf633608b118
    cd /opt/forainet/src/MinkowskiEngine
    python3.8 setup.py install --blas=openblas --force_cuda

    git clone https://github.com/mit-han-lab/torchsparse.git \
        /opt/forainet/src/torchsparse
    git -C /opt/forainet/src/torchsparse checkout --detach \
        74099d10a51c71c14318bce63d6421f698b24f24
    test "$(git -C /opt/forainet/src/torchsparse rev-parse HEAD)" = \
        74099d10a51c71c14318bce63d6421f698b24f24
    python3.8 -m pip install --no-cache-dir /opt/forainet/src/torchsparse

    git clone https://github.com/scikit-learn-contrib/hdbscan.git \
        /opt/forainet/src/hdbscan
    git -C /opt/forainet/src/hdbscan checkout --detach \
        ec3b205fbd7da9f1e41b9d83cdf3f6236e2ef1c4
    test "$(git -C /opt/forainet/src/hdbscan rev-parse HEAD)" = \
        ec3b205fbd7da9f1e41b9d83cdf3f6236e2ef1c4
    python3.8 -m pip install --no-cache-dir /opt/forainet/src/hdbscan

    python3.8 -m pip install --no-cache-dir \
        numba==0.57.1 \
        numpy==1.24.4 \
        pykdtree==1.3.7.post0

    python3.8 - <<'PY'
import hdbscan
import hydra
import MinkowskiEngine
import numpy
import omegaconf
import torch
import torch_cluster
import torch_geometric
import torch_points_kernels
import torch_scatter
import torch_sparse
import torchsparse

assert torch.__version__ == "1.9.0+cu111"
assert numpy.__version__ == "1.24.4"
PY

    apt-get clean
    rm -rf /var/lib/apt/lists/* /root/.cache/pip

%runscript
    exec python3.8 "$@"

%test
    python3.8 -c 'import MinkowskiEngine, hdbscan, torch, torch_points_kernels; print(torch.__version__)'
