Bootstrap: docker
From: pytorch/pytorch@sha256:58d848c38665fd3ed20bee65918255cb083637c860eb4fae67face2fb2ff5702

%labels
    org.opencontainers.image.title ForestFormer3D benchmark environment
    org.opencontainers.image.source https://github.com/SmartForest-no/ForestFormer3D
    org.opencontainers.image.revision 6a75c3735e4a4108d02ee944a8b93177f2360a4f
    org.opencontainers.image.licenses CC-BY-NC-4.0
    org.opencontainers.image.base.digest sha256:58d848c38665fd3ed20bee65918255cb083637c860eb4fae67face2fb2ff5702
    org.openai.benchmark.dataset for-instance
    org.openai.benchmark.method forestformer3d

%environment
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export PYTHONPATH=/opt/forestformer3d

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH

    apt-key adv --fetch-keys \
        https://developer.download.nvidia.com/compute/cuda/repos/ubuntu1804/x86_64/3bf863cc.pub
    apt-key adv --fetch-keys \
        https://developer.download.nvidia.com/compute/machine-learning/repos/ubuntu1804/x86_64/7fa2af80.pub
    apt-get update
    apt-get install -y \
        ffmpeg \
        libsm6 \
        libxext6 \
        git \
        ninja-build \
        libglib2.0-0 \
        libxrender-dev \
        cmake \
        build-essential \
        software-properties-common
    add-apt-repository ppa:ubuntu-toolchain-r/test
    apt-get update
    apt-get install -y gcc-9 g++-9
    update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-9 60
    update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-9 60
    apt-get install -y \
        python3-dev \
        python3-pip \
        libopenblas-dev \
        nvidia-utils-530 \
        nvidia-cuda-dev

    pip install debugpy

    pip install --no-deps \
        mmengine==0.7.3 \
        mmdet==3.0.0 \
        mmsegmentation==1.0.0 \
        git+https://github.com/open-mmlab/mmdetection3d.git@22aaa47fdb53ce1870ff92cb7e3f96ae38d17f61
    pip install \
        mmcv==2.0.0 \
        -f https://download.openmmlab.com/mmcv/dist/cu116/torch1.13.0/index.html \
        --no-deps

    TORCH_CUDA_ARCH_LIST="8.0" \
        pip install \
        git+https://github.com/NVIDIA/MinkowskiEngine.git@02fc608bea4c0549b0a7b00ca1bf15dee4a0b228 \
        -v \
        --no-deps \
        --install-option="--blas=openblas" \
        --install-option="--force_cuda"

    mkdir -p /opt/build
    git clone https://github.com/rusty1s/pytorch_scatter.git \
        /opt/build/pytorch_scatter
    git -C /opt/build/pytorch_scatter checkout tags/2.0.9 -b v2.0.9
    (
        cd /opt/build/pytorch_scatter
        TORCH_CUDA_ARCH_LIST="6.1;7.0;8.0" FORCE_CUDA=1 pip install .
    )

    git clone https://github.com/Karbo123/segmentator.git \
        /opt/build/segmentator
    git -C /opt/build/segmentator reset --hard \
        76efe46d03dd27afa78df972b17d07f2c6cfb696
    mkdir /opt/build/segmentator/csrc/build
    (
        cd /opt/build/segmentator/csrc/build
        cmake .. \
            -DCMAKE_PREFIX_PATH="$(python -c 'import torch; print(torch.utils.cmake_prefix_path())')" \
            -DPYTHON_INCLUDE_DIR="$(python -c 'from distutils.sysconfig import get_python_inc; print(get_python_inc())')" \
            -DPYTHON_LIBRARY="$(python -c 'import distutils.sysconfig as sysconfig; print(sysconfig.get_config_var("LIBDIR") + "/libpython3.10.so")')" \
            -DCMAKE_INSTALL_PREFIX="$(python -c 'from distutils.sysconfig import get_python_lib; print(get_python_lib())')"
        make -j2
        make install
    )

    pip install --no-deps \
        spconv-cu116==2.3.6 \
        addict==2.4.0 \
        yapf==0.33.0 \
        termcolor==2.3.0 \
        packaging==23.1 \
        numpy==1.24.1 \
        rich==13.3.5 \
        opencv-python==4.7.0.72 \
        pycocotools==2.0.6 \
        Shapely==1.8.5 \
        scipy==1.10.1 \
        terminaltables==3.1.10 \
        numba==0.57.0 \
        llvmlite==0.40.0 \
        pccm==0.4.7 \
        ccimport==0.4.2 \
        pybind11==2.10.4 \
        ninja==1.11.1 \
        lark==1.1.5 \
        cumm-cu116==0.4.9 \
        pyquaternion==0.9.9 \
        lyft-dataset-sdk==0.0.8 \
        pandas==2.0.1 \
        python-dateutil==2.8.2 \
        matplotlib==3.5.2 \
        pyparsing==3.0.9 \
        cycler==0.11.0 \
        kiwisolver==1.4.4 \
        scikit-learn==1.2.2 \
        joblib==1.2.0 \
        threadpoolctl==3.1.0 \
        cachetools==5.3.0 \
        nuscenes-devkit==1.1.10 \
        trimesh==3.21.6 \
        open3d==0.17.0 \
        plotly==5.18.0 \
        dash==2.14.2 \
        plyfile==1.0.2 \
        flask==3.0.0 \
        werkzeug==3.0.1 \
        click==8.1.7 \
        blinker==1.7.0 \
        itsdangerous==2.1.2 \
        importlib_metadata==2.1.2 \
        zipp==3.17.0 \
        tensorboard==2.15.1 \
        tensorboard-data-server==0.7.2 \
        protobuf \
        absl-py \
        future \
        MarkupSafe==2.0.1 \
        markdown \
        grpcio \
        google-auth-oauthlib \
        google-auth \
        requests-oauthlib \
        oauthlib

    pip install --no-deps --no-cache-dir torch-points-kernels==0.7.0
    pip uninstall -y torch-cluster || true
    pip install --no-deps --no-cache-dir torch-cluster

    git init /opt/forestformer3d
    git -C /opt/forestformer3d remote add origin \
        https://github.com/SmartForest-no/ForestFormer3D.git
    git -C /opt/forestformer3d fetch --depth=1 origin \
        6a75c3735e4a4108d02ee944a8b93177f2360a4f
    git -C /opt/forestformer3d checkout --detach FETCH_HEAD
    test "$(git -C /opt/forestformer3d rev-parse HEAD)" = \
        "6a75c3735e4a4108d02ee944a8b93177f2360a4f"
    test -z "$(git -C /opt/forestformer3d status --porcelain)"

    test "$(sha256sum /opt/forestformer3d/replace_mmdetection_files/loops.py | cut -d ' ' -f 1)" = \
        "df3b0d6688ae4f911fa6cbe8b1afb90520b1d147b3da800ee22075993a0bae27"
    test "$(sha256sum /opt/forestformer3d/replace_mmdetection_files/base_model.py | cut -d ' ' -f 1)" = \
        "9fb88239dd8eeddadbe6c909dc6bd5d613d3bbd487e272592972c856e56e233d"
    test "$(sha256sum /opt/forestformer3d/replace_mmdetection_files/transforms_3d.py | cut -d ' ' -f 1)" = \
        "c1a34b5a2ce006739fd1b810fdbe9cfc12f4b443acf389df71c6228aad690be9"

    cp /opt/forestformer3d/replace_mmdetection_files/loops.py \
        /opt/conda/lib/python3.10/site-packages/mmengine/runner/loops.py
    cp /opt/forestformer3d/replace_mmdetection_files/base_model.py \
        /opt/conda/lib/python3.10/site-packages/mmengine/model/base_model/base_model.py
    cp /opt/forestformer3d/replace_mmdetection_files/transforms_3d.py \
        /opt/conda/lib/python3.10/site-packages/mmdet3d/datasets/transforms/transforms_3d.py

%test
    export PYTHONPATH=/opt/forestformer3d
    test "$(git -C /opt/forestformer3d rev-parse HEAD)" = \
        "6a75c3735e4a4108d02ee944a8b93177f2360a4f"
    python -c "import torch; print(torch.__version__, torch.version.cuda)"
    python -c "import mmengine, mmdet, mmseg, mmdet3d"
    python -c "import spconv, MinkowskiEngine"
    python -c "from torch_points_kernels import instance_iou"
    python -c "import torch_cluster"
    python -c "import oneformer3d"

%runscript
    cd /opt/forestformer3d
    exec "$@"
